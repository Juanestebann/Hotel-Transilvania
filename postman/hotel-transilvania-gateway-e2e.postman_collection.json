{
  "info": {
    "_postman_id": "5375d6d4-9d5a-4f86-97dc-80b4f1f2a8a1",
    "name": "Hotel Transilvania - E2E Gateway",
    "description": "Evidencia versionable de interoperabilidad E2E via API Gateway. Todas las requests usan {{baseUrl}} y validan X-Correlation-Id.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('correlationId')) {",
          "  pm.environment.set('correlationId', pm.variables.replaceIn('{{$guid}}'));",
          "}",
          "if (!pm.environment.get('runSuffix')) {",
          "  const suffix = Date.now().toString().slice(-6);",
          "  pm.environment.set('runSuffix', suffix);",
          "  pm.environment.set('rutDocumento', `E2E-${suffix}`);",
          "  pm.environment.set('numeroHabitacion', `E2E-${suffix}`);",
          "}",
          "const now = new Date().toISOString().slice(0, 19);",
          "pm.environment.set('fechaCreacion', now);",
          "pm.environment.set('fechaPago', now);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Gateway devuelve X-Correlation-Id', function () {",
          "  const header = pm.response.headers.get('X-Correlation-Id');",
          "  pm.expect(header, 'X-Correlation-Id').to.exist;",
          "  const expected = pm.variables.get('correlationId');",
          "  if (expected) {",
          "    pm.expect(header).to.eql(expected);",
          "  }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 Setup autenticacion",
      "item": [
        {
          "name": "Login ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login admin 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('token admin presente', function () { pm.expect(json.token).to.be.a('string').and.not.empty; });",
                  "pm.test('rol admin', function () { pm.expect(json.rol).to.eql('ADMIN'); });",
                  "pm.environment.set('adminToken', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
